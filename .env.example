# ─── Discord ───────────────────────────────────────────────
# Bot token from the Discord Developer Portal (Bot tab → Reset/Copy Token)
DISCORD_BOT_TOKEN=

# (optional) Fallback channel id for notifications whose originating folder isn't
# linked to any channel. Leave blank to drop unroutable notifications.
# Channel ownership is claimed at runtime with !login, so NO user ids go here.
DISCORD_CHANNEL_ID=

# ─── Notify endpoint (Claude Code hooks → Discord) ─────────
NOTIFY_SECRET=change-me-to-something-random
NOTIFY_PORT=8787

# ─── Claude (optional) ─────────────────────────────────────
# Force a model for bot-driven sessions (else Claude Code's default).
CLAUDE_MODEL=
# Only if NOT logged into Claude Code with a subscription.
ANTHROPIC_API_KEY=
