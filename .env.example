# ─── Discord ───────────────────────────────────────────────
# Bot token from the Discord Developer Portal (Bot tab → Reset/Copy Token)
DISCORD_BOT_TOKEN=

# Your Discord user id — the ONLY user this bot will obey.
# (Discord → User Settings → Advanced → Developer Mode, then right-click your name → Copy User ID)
ALLOWED_USER_ID=

# Absolute path to the project folder Claude will operate in.
PROJECT_DIR=

# ─── Notify (optional: Claude Code hooks → Discord) ─────────
# Leave NOTIFY_SECRET blank to disable notifications.
NOTIFY_SECRET=
NOTIFY_PORT=8787

# ─── Claude (optional) ─────────────────────────────────────
# Force a model for bot-driven sessions (else Claude Code's default).
CLAUDE_MODEL=
# Only if NOT logged into Claude Code with a subscription.
ANTHROPIC_API_KEY=
